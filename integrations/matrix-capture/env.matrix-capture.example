SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Optional: use when your thoughts table is exposed through a non-public schema.
SUPABASE_SCHEMA=public
OPENROUTER_API_KEY=your-openrouter-key

MATRIX_HOMESERVER_URL=https://matrix.example.com
MATRIX_ACCESS_TOKEN=your-matrix-access-token
MATRIX_USER_ID=@ob1-bot:example.com
# Optional: inferred from /account/whoami when omitted.
MATRIX_DEVICE_ID=
MATRIX_ROOM_IDS=!roomA:example.com,!roomB:example.com

# Node deployments should normally leave this true so the capture device keeps a
# persistent fake-indexeddb snapshot on the mounted /data volume.
MATRIX_USE_INDEXEDDB=true
MATRIX_CRYPTO_DB_PREFIX=ob1-matrix-capture
MATRIX_CRYPTO_STORE_PASSWORD=choose-a-local-store-password
MATRIX_INDEXEDDB_PATH=/data/indexeddb
MATRIX_INDEXEDDB_SNAPSHOT_PATH=/data/indexeddb/crypto-idb-snapshot.bin

# Choose one secret storage input:
# MATRIX_SECRET_STORAGE_KEY_BASE64=
# MATRIX_SECRET_STORAGE_KEY=
MATRIX_SECRET_STORAGE_PASSPHRASE=your-secret-storage-passphrase

MATRIX_AUTOJOIN_INVITES=false
MATRIX_MAX_EVENT_AGE_MS=604800000
OPENROUTER_BASE=https://openrouter.ai/api/v1
EMBEDDING_MODEL=openai/text-embedding-3-small
CHAT_MODEL=openai/gpt-4o-mini
